# Expo client (bundled — safe for public values only; use EXPO_PUBLIC_ prefix)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key
EXPO_PUBLIC_ADMOB_IOS_BANNER_AD_UNIT_ID=ca-app-pub-your-ios-banner-ad-unit-id

# Server-only secrets — NEVER use EXPO_PUBLIC_ and NEVER import these in the Expo app.
# For Supabase Edge Functions, set via: supabase secrets set TWELVE_DATA_API_KEY=your_key
# For local edge function dev, add to supabase/.env.local (gitignored).
TWELVE_DATA_API_KEY=
